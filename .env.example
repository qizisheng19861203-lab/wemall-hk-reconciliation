# ===== 必填配置 =====

# 数据库密码
MYSQL_ROOT_PASSWORD=wemall2024

# JWT密钥（随机字符串，至少32位）
SECRET_KEY=change-this-to-a-long-random-secret-key-here

# 微盟开放平台
WEMALL_APP_KEY=your_app_key
WEMALL_APP_SECRET=your_app_secret
WEMALL_SHOP_ID=your_shop_id

# 汇率API（https://www.exchangerate-api.com 免费注册）
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key

# 腾讯云短信
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_SMS_SDK_APP_ID=your_sms_app_id
TENCENT_SMS_SIGN_NAME=微盟香港对账
TENCENT_SMS_SETTLEMENT_TEMPLATE_ID=your_template_id

# 结算通知手机号（多个用逗号分隔，格式：13800138000,13900139000）
SETTLEMENT_NOTIFY_PHONE=your_phone

# ===== 可选配置 =====

# CORS（生产环境改为实际域名）
CORS_ORIGINS=*
